#!/bin/bash
# ============================================
# 实时同步脚本模板（本地构建 + Docker 挂载模式）
# 前端：本地构建 → 同步 dist → Nginx 服务
# 后端：同步源码 → nodemon 自动重启
# ============================================

LOCAL_DIR="$(cd "$(dirname "$0")" && pwd)"
REMOTE_HOST="${REMOTE_USER:-user}@${REMOTE_SERVER:-server}"
REMOTE_DIR="~/projects/$(basename $LOCAL_DIR)"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# 修复权限（Mac→Linux 权限差异）
fix_permissions() {
  ssh $REMOTE_HOST "chmod -R 755 $REMOTE_DIR/apps/*/dist/ 2>/dev/null || true"
}

# 重启后端容器
restart_backend() {
  echo -e "${YELLOW}🔄 重启后端服务...${NC}"
  ssh $REMOTE_HOST "cd $REMOTE_DIR && docker compose restart backend"
}

# 构建前端
build_frontend() {
  local app_name=$1
  cd "$LOCAL_DIR/apps/$app_name" || return 1
  
  echo -e "${YELLOW}🔨 构建 $app_name...${NC}"
  if ! npm run build; then
    echo -e "${RED}❌ $app_name 构建失败！${NC}"
    return 1
  fi
  echo -e "${GREEN}✅ $app_name 构建成功${NC}"
}

# 检测源码变更
has_source_change() {
  local changed_files=$1
  local app_name=$2
  echo "$changed_files" | grep -q "apps/$app_name/src/"
}

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}  开发环境同步工具${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""
echo -e "📁 本地目录: $LOCAL_DIR"
echo -e "🖥️  目标服务器: $REMOTE_HOST"
echo -e "📂 远程目录: $REMOTE_DIR"
echo -e "🔥 部署模式: 本地构建 + Docker 挂载"
echo ""

# 首次同步
echo -e "${YELLOW}📦 首次同步...${NC}"
rsync -avz --delete \
  --exclude='.git' \
  --exclude='node_modules' \
  --exclude='.DS_Store' \
  "$LOCAL_DIR/" "$REMOTE_HOST:$REMOTE_DIR/"

fix_permissions

echo -e "${GREEN}✅ 首次同步完成${NC}"
echo ""
echo -e "${YELLOW}🔍 开始监听文件变化...（按 Ctrl+C 停止）${NC}"
echo ""

# 实时监听
fswatch -o "$LOCAL_DIR" | while read f; do
  echo -e "${YELLOW}📝 检测到变更 $(date '+%H:%M:%S')${NC}"
  
  CHANGED_FILES=$(find "$LOCAL_DIR/apps" -type f -mmin -0.1 2>/dev/null)
  
  # 前端：构建
  if has_source_change "$CHANGED_FILES" "pc-admin"; then
    build_frontend "pc-admin" || continue
  fi
  
  if has_source_change "$CHANGED_FILES" "mobile-h5"; then
    build_frontend "mobile-h5" || continue
  fi
  
  # 检查后端变更
  BACKEND_CHANGED=false
  if echo "$CHANGED_FILES" | grep -q "apps/backend/src/"; then
    BACKEND_CHANGED=true
  fi
  
  # 同步到服务器
  rsync -avz --delete \
    --exclude='.git' \
    --exclude='node_modules' \
    --exclude='.DS_Store' \
    "$LOCAL_DIR/" "$REMOTE_HOST:$REMOTE_DIR/"
  
  fix_permissions
  
  # 后端：重启容器
  if [ "$BACKEND_CHANGED" = true ]; then
    restart_backend
  fi
  
  echo -e "${GREEN}✅ 同步完成 $(date '+%H:%M:%S')${NC}"
  echo ""
done
