# 数据库连接配置
DATABASE_URL="mysql://username:password@localhost:3306/ticket_module?schema=public"

# 加密密钥 (32字节，用于AES-256-CBC加密敏感字段)
# 生成命令: openssl rand -base64 32
ENCRYPTION_KEY="your-32-byte-encryption-key-here!!!"

# 环境配置
NODE_ENV="development"

# Redis 配置 (用于核销码池、会话、限流)
REDIS_URL="redis://localhost:6379"

# JWT 配置
JWT_SECRET="your-jwt-secret-key"
JWT_EXPIRES_IN="2h"

# 阿里云OSS配置 (文件上传)
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET=""
OSS_REGION=""

# 服务器端口
PORT=3000
