# 数据库配置
DATABASE_URL="mysql://username:password@localhost:3306/ticket_db"

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
